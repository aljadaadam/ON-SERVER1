<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OnServer1" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">#FF0F0F23</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Splash theme: plain dark, NO icon -->
    <style name="Theme.OnServer1.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF0D0620</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.OnServer1</item>
    </style>
</resources>

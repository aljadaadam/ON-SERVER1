generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Authentication
// ============================================
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  phone         String?   @unique
  password      String
  name          String
  avatar        String?
  balance       Float     @default(0)
  role          Role      @default(USER)
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  otpCodes      OtpCode[]
  orders        Order[]
  transactions  Transaction[]
  refreshTokens RefreshToken[]
  deposits      Deposit[]

  @@map("users")
}

model OtpCode {
  id        String   @id @default(uuid())
  code      String
  type      OtpType
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ============================================
// Products & Categories
// ============================================
model Category {
  id          String    @id @default(uuid())
  name        String
  nameAr      String?
  icon        String?
  image       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  parentId    String?
  parent      Category? @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id              String        @id @default(uuid())
  name            String
  nameAr          String?
  description     String?
  descriptionAr   String?
  price           Float
  originalPrice   Float?
  costPrice       Float?        // Cost price from provider
  image           String?
  images          String?       // JSON string of image URLs
  type            ProductType   @default(SERVICE)
  serviceType     String?       // IMEI, SERVER, REMOTE from provider
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  isFeatured      Boolean       @default(false)
  isActive        Boolean       @default(true)
  stock           Int?
  metadata        Json?
  externalId      String?       // SERVICEID from provider
  fields          String?       // JSON: [{name, key, type, required}] custom fields
  deliveryTime    String?       // e.g. "Minutes", "Hours"
  supportsQnt     Boolean       @default(false)
  minQnt          Int           @default(0)
  maxQnt          Int           @default(0)
  groupName       String?       // Catalog group from provider
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  orderItems      OrderItem[]

  @@map("products")
}

// ============================================
// Orders & Transactions
// ============================================
model Order {
  id              String       @id @default(uuid())
  orderNumber     String       @unique
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  status          OrderStatus  @default(PENDING)
  totalAmount     Float
  notes           String?
  externalOrderId String?      // Reference ID from SD-Unlocker
  responseData    String?      // JSON response from provider
  resultCodes     String?      // JSON: codes/keys returned
  items           OrderItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int     @default(1)
  price       Float
  metadata    String? // JSON: user-provided field values
  imei        String? // IMEI sent to provider

  @@map("order_items")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Float
  balance     Float
  description String?
  reference   String?
  createdAt   DateTime        @default(now())

  @@map("transactions")
}

// ============================================
// Banners & Settings
// ============================================
model Banner {
  id        String   @id @default(uuid())
  title     String?
  image     String
  link      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
  
  @@map("settings")
}

// ============================================
// Deposits (Payment Gateways)
// ============================================
model Deposit {
  id              String        @id @default(uuid())
  depositNumber   Int           @unique
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  amount          Float
  amountLocal     Float?        // Amount in local currency (for Bankak)
  exchangeRate    Float?        // Exchange rate used
  gateway         String        // USDT or BANKAK
  status          DepositStatus @default(PENDING)
  txHash          String?       // BEP20 transaction hash
  receiptImage    String?       // Bankak receipt image path
  adminNote       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("deposits")
}

model DepositCounter {
  id      String @id @default("deposit_counter")
  counter Int    @default(1000)
  
  @@map("deposit_counters")
}

// ============================================
// Enums
// ============================================
enum DepositStatus {
  PENDING
  CONFIRMED
  REJECTED
  EXPIRED
}
enum Role {
  USER
  ADMIN
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
}

enum ProductType {
  SERVICE
  GIFT_CARD
  GAME_CARD
  TOP_UP
  SUBSCRIPTION
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  PURCHASE
  REFUND
}
